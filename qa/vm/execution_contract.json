{
  "schema": "zig-scheduler/vm-execution-contract/v1",
  "status": "implemented-disposable-vm-runner",
  "host_mutation": false,
  "modes": [
    "auto",
    "execute",
    "host-safe",
    "read-only-smoke",
    "vm-required"
  ],
  "inputs": {
    "image": {
      "required_for_execute": true,
      "source": [
        "--image",
        "ZIG_SCHEDULER_VM_IMAGE"
      ],
      "must_be_file": true,
      "required_for_vm_required_release": true,
      "refusal_reason": "VM_CONFIG_INVALID"
    },
    "kernel": {
      "required_for_execute": false,
      "source": [
        "--kernel",
        "ZIG_SCHEDULER_VM_KERNEL"
      ],
      "must_be_file": true,
      "required_for_microvm_live": true,
      "refusal_reason": "kernel_image_unavailable"
    },
    "env_file": {
      "required_for_execute": false,
      "parsed_as_data_only": true,
      "allowed_keys": [
        "ZIG_SCHEDULER_VM_IMAGE",
        "ZIG_SCHEDULER_VM_KERNEL",
        "ZIG_SCHEDULER_VM_DRIVER",
        "ZIG_SCHEDULER_VM_TEST_FIXTURE"
      ]
    },
    "nix": {
      "required_for_microvm_live": true,
      "source": [
        "ZIG_SCHEDULER_NIX_BIN",
        "trusted PATH locations"
      ],
      "trusted_canonical_paths": [
        "/usr/bin/nix",
        "/run/current-system/sw/bin/nix",
        "/nix/var/nix/profiles/default/bin/nix",
        "/nix/profile/bin/nix",
        "/nix/store/*/bin/nix"
      ],
      "refusal_reason": "nix_busybox_unavailable"
    },
    "bpf_object": {
      "required_for_vm_required_release": true,
      "path": "zig-out/bpf/zigsched_minimal.bpf.o",
      "metadata": "zig-out/bpf/zigsched_minimal.bpf.meta.json",
      "build_command": "zig build bpf",
      "skip_is_release_eligible": false,
      "required_metadata_fields": [
        "policy_name",
        "object_hash",
        "tuple",
        "tool_versions",
        "struct_ops",
        "vm_only",
        "vm_marker_required",
        "host_mutation",
        "host_attach_allowed"
      ],
      "metadata_schema": "zig-scheduler/bpf-object-metadata/v1",
      "skip_schema": "zig-scheduler/bpf-build-skip/v1",
      "vm_marker_required": "/run/zig-scheduler-vm-lab.marker"
    }
  },
  "guest_marker": {
    "path": "/run/zig-scheduler-vm-lab.marker",
    "required_before_attach": true,
    "required_for_vm_live_evidence": true
  },
  "copy_in": [
    "zig-out/bpf/zigsched_minimal.bpf.o",
    "zig-out/bpf/zigsched_minimal.bpf.meta.json",
    "qa/vm/verifier_only.sh",
    "qa/vm/partial_attach.sh",
    "qa/vm/observe_partial.sh",
    "qa/vm/rollback_drill.sh"
  ],
  "copy_out": [
    "manifest.json",
    "attestation.json",
    "transcript.jsonl",
    "bpf-verifier.log",
    "runtime-samples.jsonl",
    "rollback-result.json",
    "cleanup-receipt.json",
    "audit-ledger.jsonl",
    "summary.json"
  ],
  "command_allowlist": [
    {
      "name": "verifier_only",
      "argv0": "qa/vm/verifier_only.sh",
      "mutation_capable": false
    },
    {
      "name": "partial_attach",
      "argv0": "qa/vm/partial_attach.sh",
      "mutation_capable": true,
      "requires_audit_id": true,
      "requires_rollback_id": true,
      "requires_guest_marker": true
    },
    {
      "name": "observe_partial",
      "argv0": "qa/vm/observe_partial.sh",
      "mutation_capable": false,
      "requires_guest_marker": true
    },
    {
      "name": "rollback_drill",
      "argv0": "qa/vm/rollback_drill.sh",
      "mutation_capable": true,
      "requires_rollback_id": true,
      "requires_guest_marker": true
    }
  ],
  "timeouts": {
    "boot_sec": 120,
    "command_sec": 300,
    "teardown_sec": 60,
    "overall_sec": 600
  },
  "teardown": {
    "always_attempt": true,
    "terminate_qemu": true,
    "remove_temp_roots": true,
    "record_process_receipt": true,
    "fail_on_orphan_qemu": true
  },
  "artifact_manifest": {
    "schema": "zig-scheduler/vm-transcript-index/v1",
    "required_fields": [
      "git_sha",
      "host_mutation",
      "vm_marker",
      "kernel_tuple",
      "command_allowlist_hash",
      "copy_in_hashes",
      "copy_out_hashes",
      "transcript_path",
      "cleanup_receipt"
    ]
  },
  "implementation_gate": {
    "execute_mode_t15": "fixture-gated",
    "reason": "real-qemu-command-transport-requires-later-signed-vm-profile"
  },
  "backend_entrypoint": {
    "build_target": "vm-lab-backend",
    "command": "zig build vm-lab-backend",
    "implementation_status": "implemented-disposable-vm-runner",
    "implementation_task": "Task 8",
    "help_command": "zig build vm-lab-backend -- --help",
    "vm_required_command": "zig build vm-lab-backend -- --mode vm-required --out evidence/lab/<run-id>",
    "default_out": "evidence/lab/vm-backend-final",
    "host_default": "fail-closed-no-attach",
    "event_jsonl": "daemon-events.jsonl"
  },
  "trusted_qemu_discovery": {
    "script": "qa/vm/qemu_discovery.sh",
    "binary": "qemu-system-x86_64",
    "override_source": [
      "--qemu",
      "ZIG_SCHEDULER_QEMU_BIN"
    ],
    "trusted_canonical_paths": [
      "/usr/bin/qemu-system-x86_64",
      "/run/current-system/sw/bin/qemu-system-x86_64",
      "/nix/store/*/bin/qemu-system-x86_64"
    ],
    "refuse_paths": [
      "relative paths",
      "/home/*",
      "/tmp/*",
      "/var/tmp/*",
      "/dev/shm/*",
      "paths containing traversal components",
      "*/.zig-cache/*",
      "*/.omo/*",
      "*/.omx/*"
    ],
    "refusal_reason": "qemu override refused",
    "incident": "qemu_untrusted_or_unavailable",
    "must_not_execute_untrusted_candidate": true
  },
  "vm_tuple_requirements": {
    "arch": [
      "x86_64"
    ],
    "kvm": {
      "required": true,
      "path": "/dev/kvm",
      "incident": "kvm_unavailable"
    },
    "kernel": {
      "image_required": true,
      "config_required": [
        "CONFIG_SCHED_CLASS_EXT",
        "CONFIG_BPF",
        "CONFIG_BPF_SYSCALL",
        "CONFIG_BPF_JIT",
        "CONFIG_DEBUG_INFO_BTF"
      ],
      "sched_ext_state_path": "/sys/kernel/sched_ext/state",
      "sched_ext_enable_seq_path": "/sys/kernel/sched_ext/enable_seq"
    },
    "btf": {
      "required": true,
      "path": "/sys/kernel/btf/vmlinux",
      "incident": "btf_unavailable"
    },
    "cgroup_v2": {
      "required": true,
      "path": "/sys/fs/cgroup",
      "incident": "cgroup_v2_unavailable"
    },
    "sched_ext": {
      "required": true,
      "state_path": "/sys/kernel/sched_ext/state",
      "incident": "sched_ext_unavailable"
    }
  },
  "evidence_layout": {
    "backend_default_out": "evidence/lab/vm-backend-final",
    "run_all_summary": "evidence/lab/run-all/vm-backend-final/summary.json",
    "release_current_run": "evidence/releases/0.2.0-lab-runall/current",
    "required_files": [
      "manifest.json",
      "attestation.json",
      "transcript.jsonl",
      "bpf-verifier.log",
      "runtime-samples.jsonl",
      "rollback-result.json",
      "cleanup-receipt.json",
      "audit-ledger.jsonl",
      "summary.json"
    ],
    "host_mutation_required_value": false,
    "fixture_release_eligible": false,
    "backend_event_jsonl": "evidence/lab/<run-id>/daemon-events.jsonl"
  },
  "event_schemas": {
    "transcript_index": "zig-scheduler/vm-transcript-index/v1",
    "lifecycle_event": "zig-scheduler/vm-lab-lifecycle-event/v1",
    "incident_event": "zig-scheduler/vm-lab-incident/v1",
    "runtime_sample": "zig-scheduler/runtime-sample/v1",
    "audit_ledger": "zig-scheduler/audit-ledger/v1",
    "run_all_summary": "zig-scheduler/run-all-lab/v1"
  },
  "bpf_ownership": {
    "kernel_program_source": "C",
    "kernel_program_toolchain": "clang -target bpf",
    "reason": "kernel ABI, verifier, struct_ops, and libbpf/bpftool compatibility",
    "zig_owns": [
      "build graph",
      "orchestration",
      "metadata validation",
      "VM lab runner entrypoint",
      "evidence schema checks",
      "packaging",
      "release gates"
    ],
    "host_attach_allowed": false,
    "vm_attach_requires": [
      "guest_marker",
      "audit_id",
      "rollback_id",
      "verifier_success",
      "tuple_gates"
    ]
  },
  "stable_live_proof": {
    "description": "Static VM-live bundle semantics required before a run-all summary may be treated as live proof. Runtime ordering, counter growth, cgroup digest comparisons, and daemon-event occurrence checks remain in live_behavior_check.py and live_summary.zig.",
    "summary_schema": "zig-scheduler/run-all-lab/v1",
    "status": "PASS",
    "evidence_mode": "vm-live",
    "vm_kind": "qemu-vm",
    "host_mutation": false,
    "release_eligible_live_proof": false,
    "vm_marker_path": "/run/zig-scheduler-vm-lab.marker",
    "vm_marker_present": true,
    "rollback_result": "PASS",
    "cleanup": {
      "required": true,
      "required_values": {
        "qemu_leftovers": false,
        "tmux_leftovers": false,
        "process_group_reaped": true,
        "temp_dirs_removed": true
      },
      "timeout_rc_must_not_equal": 124
    },
    "required_artifact_paths": [
      "partial-attach/partial-attach-evidence.json",
      "observe-partial/summary.json",
      "observe-partial/runtime-samples.jsonl",
      "observe-partial/daemon-runtime-events.jsonl",
      "rollback-drill/audit-ledger.jsonl"
    ],
    "observe_summary": {
      "schema": "zig-scheduler/observe-partial-summary/v1",
      "required_fields": [
        "schema",
        "status",
        "evidence_mode",
        "runtime_samples",
        "daemon_runtime_events",
        "sample_count",
        "workload_alive_all_samples",
        "final_ops",
        "final_state",
        "final_state_disabled_or_rolled_back",
        "private_command_lines_sampled",
        "release_eligible_live_proof"
      ],
      "required_values": {
        "status": "PASS",
        "evidence_mode": "vm-live",
        "workload_alive_all_samples": true,
        "final_state_disabled_or_rolled_back": true,
        "private_command_lines_sampled": false,
        "release_eligible_live_proof": false
      },
      "sample_count_min": 3
    },
    "partial_attach": {
      "schema": "zig-scheduler/partial-attach-evidence/v1",
      "required_fields": [
        "schema",
        "host_mutation",
        "release_eligible_live_proof",
        "object",
        "object_sha256",
        "ops_during_attach",
        "switch_mode",
        "target_cgroup",
        "rollback_id",
        "rollback_status",
        "post_state",
        "transcript_path"
      ],
      "required_values": {
        "host_mutation": false,
        "release_eligible_live_proof": false,
        "ops_during_attach": "zigsched_minimal",
        "switch_mode": "SCX_OPS_SWITCH_PARTIAL",
        "rollback_status": "PASS"
      },
      "target_cgroup_prefix": "/sys/fs/cgroup/zig-scheduler-lab.slice/",
      "object_sha256_shape": "sha256-hex-64-nonzero"
    },
    "runtime_sample_artifact": {
      "path_suffix": "observe-partial/runtime-samples.jsonl",
      "schema": "zig-scheduler/runtime-sample/v1",
      "required_fields": [
        "schema",
        "sequence",
        "ops",
        "state",
        "events",
        "workload_alive",
        "private_command_lines_sampled",
        "cgroup_membership_digest",
        "cgroup_membership_status"
      ],
      "required_values": {
        "workload_alive": true,
        "private_command_lines_sampled": false
      }
    },
    "daemon_runtime_event_artifact": {
      "path_suffix": "observe-partial/daemon-runtime-events.jsonl",
      "schema": "zig-scheduler/daemon-event/v1",
      "event": "runtime_sample",
      "required_fields": [
        "schema",
        "event",
        "ops",
        "host_mutation"
      ],
      "required_values": {
        "host_mutation": false
      }
    },
    "validator_boundaries": {
      "kept_in_runtime_validators": [
        "sample ordering before/during/after attach",
        "counter growth and explicit counter fact validation",
        "cgroup membership digest validation",
        "daemon runtime_sample occurrence and zigsched_minimal occurrence checks"
      ]
    }
  }
}
