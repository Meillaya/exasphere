{
  "$id": "zig-scheduler/matrix-run/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "action_id": {
      "maxLength": 96,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "audit_id": {
      "pattern": "^AUD-[0-9]{8}T[0-9]{6}Z-[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "bpf_abi_version": {
      "const": "zigsched-bpf-abi-v1"
    },
    "cleanup_proof_path": {
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "type": "string"
    },
    "daemon_event_path": {
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "type": "string"
    },
    "evidence_mode": {
      "enum": [
        "vm-live",
        "host-refusal-only",
        "fixture"
      ],
      "type": "string"
    },
    "git": {
      "additionalProperties": false,
      "properties": {
        "actual_sha": {
          "minLength": 7,
          "type": "string"
        },
        "dirty": {
          "const": false
        },
        "expected_sha": {
          "minLength": 7,
          "type": "string"
        },
        "status": {
          "const": "current"
        }
      },
      "required": [
        "expected_sha",
        "actual_sha",
        "status",
        "dirty"
      ],
      "type": "object"
    },
    "host_mutation": {
      "const": false
    },
    "host_refusal_proof_path": {
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "type": "string"
    },
    "incident_path": {
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "type": "string"
    },
    "kernel_tuple": {
      "additionalProperties": false,
      "properties": {
        "arch": {
          "minLength": 1,
          "type": "string"
        },
        "btf": {
          "enum": [
            "present",
            "missing",
            "unknown"
          ],
          "type": "string"
        },
        "kernel_release": {
          "minLength": 1,
          "type": "string"
        },
        "kvm": {
          "enum": [
            "available",
            "unavailable",
            "unknown"
          ],
          "type": "string"
        },
        "sched_ext": {
          "enum": [
            "available",
            "unavailable",
            "unknown"
          ],
          "type": "string"
        }
      },
      "required": [
        "kernel_release",
        "arch",
        "btf",
        "kvm",
        "sched_ext"
      ],
      "type": "object"
    },
    "matrix_run_id": {
      "maxLength": 96,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "outcome": {
      "enum": [
        "PASS",
        "SKIP",
        "REFUSE",
        "INCIDENT",
        "FAIL"
      ],
      "type": "string"
    },
    "policy": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "object_path": {
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
          "type": "string"
        },
        "object_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "source_path": {
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
          "type": "string"
        },
        "source_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "name",
        "object_path",
        "object_sha256",
        "source_path",
        "source_sha256"
      ],
      "type": "object"
    },
    "post_cgroup_state": {
      "type": "object"
    },
    "post_scheduler_state": {
      "additionalProperties": false,
      "properties": {
        "disable_reason": {
          "enum": [
            "normal_unregister",
            "scheduler_exit",
            "watchdog_stall",
            "watchdog_error",
            "sysrq_forced_disable",
            "not_applicable",
            "unavailable"
          ],
          "type": "string"
        },
        "enable_seq": {
          "pattern": "^(?:[0-9]+|unavailable)$",
          "type": "string"
        },
        "ops": {
          "minLength": 1,
          "type": "string"
        },
        "rollback_state": {
          "minLength": 1,
          "type": "string"
        },
        "root_ops": {
          "minLength": 1,
          "type": "string"
        },
        "sched_ext": {
          "enum": [
            "disabled",
            "enabled",
            "enabling",
            "disabling",
            "unknown",
            "unavailable"
          ],
          "type": "string"
        },
        "task_ext_enabled": {
          "enum": [
            "true",
            "false",
            "unknown",
            "unavailable"
          ],
          "type": "string"
        },
        "teardown_state": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "sched_ext",
        "ops"
      ],
      "type": "object"
    },
    "pre_cgroup_state": {
      "type": "object"
    },
    "pre_scheduler_state": {
      "additionalProperties": false,
      "properties": {
        "disable_reason": {
          "enum": [
            "normal_unregister",
            "scheduler_exit",
            "watchdog_stall",
            "watchdog_error",
            "sysrq_forced_disable",
            "not_applicable",
            "unavailable"
          ],
          "type": "string"
        },
        "enable_seq": {
          "pattern": "^(?:[0-9]+|unavailable)$",
          "type": "string"
        },
        "ops": {
          "minLength": 1,
          "type": "string"
        },
        "rollback_state": {
          "minLength": 1,
          "type": "string"
        },
        "root_ops": {
          "minLength": 1,
          "type": "string"
        },
        "sched_ext": {
          "enum": [
            "disabled",
            "enabled",
            "enabling",
            "disabling",
            "unknown",
            "unavailable"
          ],
          "type": "string"
        },
        "task_ext_enabled": {
          "enum": [
            "true",
            "false",
            "unknown",
            "unavailable"
          ],
          "type": "string"
        },
        "teardown_state": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "sched_ext",
        "ops"
      ],
      "type": "object"
    },
    "privacy_scan": {
      "additionalProperties": false,
      "properties": {
        "private_fields_found": {
          "const": false
        },
        "report_path": {
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
          "type": "string"
        },
        "status": {
          "const": "PASS"
        }
      },
      "required": [
        "status",
        "private_fields_found",
        "report_path"
      ],
      "type": "object"
    },
    "release_eligible": {
      "const": false
    },
    "rollback_id": {
      "maxLength": 96,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "rollback_proof_path": {
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "type": "string"
    },
    "runtime_sample_path": {
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "type": "string"
    },
    "scenario_id": {
      "maxLength": 96,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "schema": {
      "const": "zig-scheduler/matrix-run/v1"
    },
    "supported_tuple_status": {
      "enum": [
        "supported",
        "unsupported",
        "unknown"
      ],
      "type": "string"
    },
    "vm_marker": {
      "additionalProperties": false,
      "properties": {
        "checked_by": {
          "minLength": 1,
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "present": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        }
      },
      "required": [
        "required",
        "present",
        "path",
        "checked_by"
      ],
      "type": "object"
    },
    "workload": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "spec_path": {
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
          "type": "string"
        },
        "spec_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "name",
        "spec_path",
        "spec_sha256"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema",
    "matrix_run_id",
    "scenario_id",
    "outcome",
    "evidence_mode",
    "kernel_tuple",
    "supported_tuple_status",
    "vm_marker",
    "bpf_abi_version",
    "policy",
    "workload",
    "action_id",
    "audit_id",
    "rollback_id",
    "pre_scheduler_state",
    "post_scheduler_state",
    "pre_cgroup_state",
    "post_cgroup_state",
    "runtime_sample_path",
    "daemon_event_path",
    "incident_path",
    "rollback_proof_path",
    "cleanup_proof_path",
    "host_refusal_proof_path",
    "privacy_scan",
    "git",
    "release_eligible",
    "host_mutation"
  ],
  "title": "zig-scheduler VM harness matrix run evidence v1",
  "type": "object"
}
