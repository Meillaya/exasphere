{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/control/runtime-sample.v1.schema.json",
  "title": "zig-scheduler runtime sample v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "sequence",
    "state",
    "ops",
    "enable_seq",
    "events",
    "events_hash",
    "nr_rejected",
    "debug_dump",
    "policy_abi",
    "cgroup_membership_digest",
    "workload_alive",
    "private_command_lines_sampled"
  ],
  "properties": {
    "schema": {
      "const": "zig-scheduler/runtime-sample/v1"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "git_sha": {
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/fact"
    },
    "ops": {
      "$ref": "#/$defs/fact"
    },
    "enable_seq": {
      "$ref": "#/$defs/fact"
    },
    "events": {
      "$ref": "#/$defs/fact"
    },
    "events_hash": {
      "type": "string",
      "minLength": 1
    },
    "nr_rejected": {
      "$ref": "#/$defs/fact"
    },
    "debug_dump": {
      "$ref": "#/$defs/digest_fact"
    },
    "root_ops": {
      "$ref": "#/$defs/fact"
    },
    "scheduler_events": {
      "$ref": "#/$defs/fact"
    },
    "policy_counters": {
      "$ref": "#/$defs/policy_counters"
    },
    "sample_loss": {
      "$ref": "#/$defs/sample_loss"
    },
    "policy_abi": {
      "$ref": "#/$defs/policy_abi"
    },
    "cgroup_membership_digest": {
      "type": "string",
      "pattern": "^(?!0{64}$)[0-9a-f]{64}$"
    },
    "cgroup_membership_status": {
      "$ref": "#/$defs/fact"
    },
    "workload": {
      "$ref": "#/$defs/fact"
    },
    "workload_alive": {
      "type": "boolean"
    },
    "sample_source_event": {
      "type": "string"
    },
    "observation_source": {
      "type": "string",
      "enum": [
        "vm_guest_sched_ext",
        "vm_serial_sched_ext",
        "vm_fixture_sched_ext"
      ]
    },
    "private_command_lines_sampled": {
      "const": false
    },
    "dsq_depth": {
      "$ref": "#/$defs/dsq_depth"
    },
    "queue_latency": {
      "$ref": "#/$defs/queue_latency"
    },
    "fairness": {
      "$ref": "#/$defs/fairness"
    },
    "task_counts": {
      "$ref": "#/$defs/task_counts"
    },
    "scheduler_counters": {
      "$ref": "#/$defs/scheduler_counters"
    },
    "sched_ext_observation": {
      "$ref": "#/$defs/sched_ext_observation"
    },
    "benchmark_histograms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/benchmark_histogram_ref"
      }
    },
    "sched_ext_phase": {
      "type": "string",
      "enum": [
        "before_attach",
        "during_attach",
        "after_rollback"
      ]
    },
    "task_ext_enabled": {
      "$ref": "#/$defs/task_ext_enabled_fact"
    },
    "teardown_state": {
      "$ref": "#/$defs/fact"
    },
    "rollback_state": {
      "$ref": "#/$defs/fact"
    },
    "cgroup_semantic_labels": {
      "$ref": "#/$defs/cgroup_policy_semantics"
    }
  },
  "forbiddenProperties": [
    "command_line",
    "cmdline",
    "argv",
    "env",
    "environment",
    "secret",
    "api_key"
  ],
  "$defs": {
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "digest_fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "present"
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "pattern": "^sha256:[0-9a-f]{64};bytes:[0-9]+$"
              }
            }
          }
        }
      ]
    },
    "policy_counters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nr_rejected",
        "dispatch_failed",
        "fallback",
        "fatal"
      ],
      "properties": {
        "nr_rejected": {
          "type": "integer",
          "minimum": 0
        },
        "dispatch_failed": {
          "type": "integer",
          "minimum": 0
        },
        "fallback": {
          "type": "integer",
          "minimum": 0
        },
        "fatal": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "sample_loss": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lost_samples",
        "backpressure_dropped"
      ],
      "properties": {
        "lost_samples": {
          "type": "integer",
          "minimum": 0
        },
        "backpressure_dropped": {
          "type": "integer",
          "minimum": 0
        },
        "ring_buffer_overruns": {
          "type": "integer",
          "minimum": 0
        },
        "reader_lag_events": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "policy_abi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_name",
        "policy_version",
        "struct_ops",
        "object_sha256",
        "btf_required"
      ],
      "properties": {
        "policy_name": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        },
        "struct_ops": {
          "type": "string",
          "minLength": 1
        },
        "object_sha256": {
          "type": "string",
          "minLength": 1
        },
        "btf_required": {
          "type": "boolean"
        },
        "abi_version": {
          "type": "integer",
          "enum": [
            3
          ]
        },
        "abi_label": {
          "type": "string",
          "enum": [
            "zigsched-bpf-abi-v3"
          ]
        },
        "cgroup_semantics": {
          "$ref": "#/$defs/cgroup_policy_semantics"
        },
        "vm_only": {
          "const": true
        },
        "host_mutation": {
          "const": false
        },
        "production_claim": {
          "const": false
        },
        "release_eligible": {
          "const": false
        }
      }
    },
    "dsq_depth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "global",
        "local",
        "shared"
      ],
      "properties": {
        "global": {
          "type": "integer",
          "minimum": 0
        },
        "local": {
          "type": "integer",
          "minimum": 0
        },
        "shared": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "queue_latency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "p50_us",
        "p95_us",
        "p99_us",
        "max_us"
      ],
      "properties": {
        "p50_us": {
          "type": "integer",
          "minimum": 0
        },
        "p95_us": {
          "type": "integer",
          "minimum": 0
        },
        "p99_us": {
          "type": "integer",
          "minimum": 0
        },
        "max_us": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "fairness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "starved_tasks",
        "max_wait_us"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "ok",
            "watch",
            "starved",
            "unknown"
          ]
        },
        "starved_tasks": {
          "type": "integer",
          "minimum": 0
        },
        "max_wait_us": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "counter_map": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "not": {
          "pattern": "(^/|\\.\\.)"
        }
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "task_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "by_cgroup_digest",
        "by_class"
      ],
      "properties": {
        "by_cgroup_digest": {
          "$ref": "#/$defs/counter_map"
        },
        "by_class": {
          "$ref": "#/$defs/counter_map"
        }
      }
    },
    "scheduler_counters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_switches",
        "wakeups",
        "migrations"
      ],
      "properties": {
        "context_switches": {
          "type": "integer",
          "minimum": 0
        },
        "wakeups": {
          "type": "integer",
          "minimum": 0
        },
        "migrations": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "sched_ext_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dump",
        "tracepoints"
      ],
      "properties": {
        "dump": {
          "$ref": "#/$defs/digest_fact"
        },
        "tracepoints": {
          "$ref": "#/$defs/counter_map"
        }
      }
    },
    "benchmark_histogram_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_path",
        "record_sha256",
        "histogram_id",
        "record_only"
      ],
      "properties": {
        "record_path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(^/|\\.\\.)"
          }
        },
        "record_sha256": {
          "type": "string",
          "pattern": "^(?!0{64}$)[0-9a-f]{64}$"
        },
        "histogram_id": {
          "type": "string",
          "minLength": 1
        },
        "record_only": {
          "const": true
        }
      }
    },
    "cgroup_policy_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu.weight",
        "cgroup.lifecycle",
        "cgroup.move",
        "cpuset.cpus",
        "cpuset.cpus.effective",
        "cpu.pressure",
        "cpu.max",
        "uclamp",
        "cgroup_set_idle"
      ],
      "properties": {
        "cpu.weight": {
          "const": "callback-observed"
        },
        "cgroup.lifecycle": {
          "const": "observed"
        },
        "cgroup.move": {
          "const": "observed"
        },
        "cpuset.cpus": {
          "const": "observed-only"
        },
        "cpuset.cpus.effective": {
          "const": "observed-only"
        },
        "cpu.pressure": {
          "const": "observed-only"
        },
        "cpu.max": {
          "const": "deferred"
        },
        "uclamp": {
          "const": "deferred"
        },
        "cgroup_set_idle": {
          "const": "refused"
        }
      }
    },
    "task_ext_enabled_fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "present",
            "missing",
            "unreadable",
            "unknown"
          ]
        },
        "value": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "present"
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "enum": [
                  "true",
                  "false"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "missing",
                  "unreadable",
                  "unknown"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "enum": [
                  "",
                  "unknown",
                  "unavailable"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
