{
  "$id": "zig-scheduler/protected-environment-review/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "run_id",
    "run_url",
    "head_sha",
    "environment_name",
    "environment_id",
    "reviewer_status",
    "reviewer_identity",
    "reviewer_id",
    "comment",
    "review_history_api_url",
    "collected_at",
    "host_mutation",
    "release_eligible",
    "production_capacity_claim"
  ],
  "properties": {
    "schema": {
      "const": "zig-scheduler/protected-environment-review/v1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "run_url": {
      "type": "string",
      "pattern": "^https://github\\.com/[^/]+/[^/]+/actions/runs/[0-9]+$"
    },
    "head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "environment_name": {
      "const": "vm-proof-manual"
    },
    "environment_id": {
      "type": "integer",
      "minimum": 1
    },
    "reviewer_status": {
      "const": "approved"
    },
    "reviewer_identity": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_id": {
      "type": "integer",
      "minimum": 1
    },
    "comment": {
      "const": "manual protected VM proof only; not release approval"
    },
    "review_history_api_url": {
      "type": "string",
      "pattern": "^https://api\\.github\\.com/repos/[^/]+/[^/]+/actions/runs/[0-9]+/approvals$"
    },
    "collected_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "host_mutation": {
      "const": false
    },
    "release_eligible": {
      "const": false
    },
    "production_capacity_claim": {
      "const": false
    }
  }
}
