# GitHub Linguist language policy for the C++ rewrite (xsprof).
#
# The language graph reflects the C++ implementation. The archived Zig simulator
# is excluded from the breakdown so it does not appear in the language stats;
# documentation and evidence prose are marked as documentation so they do not
# skew the code-language percentages.
simulator/** linguist-generated=true
docs/** linguist-documentation=true
evidence/** linguist-documentation=true
*.md linguist-documentation=true
