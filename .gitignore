# Zig build outputs
.zig-cache/
zig-out/
simulator/.zig-cache/
simulator/zig-out/

# Local workflow/agent state
.omo/
.omx/
.debug-journal.md

# Raw ad-hoc proof/log bundles belong outside git. Curated evidence must live
# under evidence/ with a reviewed summary and be force-added deliberately.
artifacts/

# Python/local test caches
__pycache__/
*.py[cod]
.pytest_cache/

# Root daemon journals generated by local TUI/live runs; not product source.
/events.jsonl

# Local verification scratch outputs. Tracked release/governance evidence is not
# removed by these rules; intentional new evidence can still be added with git -f.
# Generated lab runs are bulky and reproducible; keep curated snapshots tracked
# deliberately, such as evidence/lab/run-all/final, and force-add new curated
# evidence only after review.
evidence/lab/**
# Curated matrix fixture referenced by the frontend contract pack; keep this
# limited to the fixture directory. Its nested .gitignore lists the exact
# canonical files, so generated siblings and incidental run output stay ignored.
!evidence/lab/
!evidence/lab/matrix/
!evidence/lab/matrix/fixture-pass/

# Local scratch verification scripts/data that are not required to build or run.
*.tmp
*.log
*.scratch.sh
*.scratch.py
qa/local-*.sh
qa/local-*.py
tools/local-*.sh
tools/local-*.py

# Local disposable VM/TUI live-run evidence. These can contain large initramfs
# bundles and are reproducible with qa/vm/run_microvm_live_lab.sh.
evidence/lab/run-all/microvm-live-*/
evidence/lab/run-all/vm-backend-final/
evidence/lab/run-all/manifest-provenance.json
evidence/lab/run-all/desktop-run-*/
evidence/lab/run-all/no-host-mutation-*/
evidence/lab/tui-e2e/*/
evidence/lab/incident-drill/tui-*/
evidence/lab/rollback-drill/tui-*/
evidence/lab/run-all/tui-*/
evidence/releases/0.2.0-lab-runall/
# Ignored current-run release evidence breaks the HEAD/freshness loop; curated
# tracked snapshots under evidence/releases/<version>/ remain explicit git adds.
evidence/releases/*-runall/current/

# Local frontend reference artifact; DESIGN.md is the committed contract.
/frontend.html

# ---- C++ rewrite (xsprof) build artifacts ----
/build/
compile_commands.json
/build-selftest
/xsprof-bin
*.o
*.a
*.so
.cache/

# VM-lab build artifacts (regenerated by qa/vm-cpp/run_vmlab.sh)
qa/vm-cpp/initrd
